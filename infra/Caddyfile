velokarte.pocs.dev {
    encode gzip zstd

    # Static frontend (CRA build output, SPA fallback)
    root * /srv/velokarte/build
    file_server
    try_files {path} /index.html

    # API
    handle /api/* {
        reverse_proxy localhost:8080
    }

    # PMTiles file (HTTP range requests served by Caddy file_server)
    handle /pmtiles/* {
        root * /srv/velokarte
        file_server
        header Cache-Control "public, max-age=300"
    }

    # Tell crawlers not to hammer our tile path (extra defence;
    # we also ship robots.txt in /srv/velokarte/build).
    header /pmtiles/* X-Robots-Tag "noindex, nofollow"
}
