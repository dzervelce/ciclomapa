velokarte.pocs.dev {
    encode gzip zstd

    # API: forward to Bun. Must come before the static-file handle so
    # PUT/POST aren't intercepted by file_server (which only allows GET/HEAD).
    handle /api/* {
        reverse_proxy localhost:8080
    }

    # PMTiles file (HTTP range requests served by Caddy file_server)
    handle /pmtiles/* {
        root * /srv/velokarte
        file_server
        header Cache-Control "public, max-age=300"
        header X-Robots-Tag "noindex, nofollow"
    }

    # Default: static frontend (SPA fallback)
    handle {
        root * /srv/velokarte/build
        file_server
        try_files {path} /index.html
    }
}
